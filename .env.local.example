# ============================================================
# Heimstadt Admin — Environment Variables
# Copy this file to .env.local and fill in your values.
# ============================================================

# Supabase (shared with main website — same project)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# The main website origin (used for CORS / linking back)
NEXT_PUBLIC_MAIN_SITE_URL=https://heimstadt.com

# GCS bucket name where the main site stores uploaded verification documents
# (bucket name only — not a secret. Used to build a direct object URL for staff
# to open a document. Requires the bucket/object to be readable by staff.)
NEXT_PUBLIC_GCS_BUCKET_NAME=heimat-storage

# Supabase service role key — SECRET, server-side only (no NEXT_PUBLIC_ prefix).
# Required to create new staff accounts from the Team page. Find it in
# Supabase Dashboard -> Project Settings -> API -> service_role key.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
